import csv
import logging
from datetime import datetime
from pathlib import Path

from airflow import DAG
from airflow.operators.trigger_dagrun import TriggerDagRunOperator

# --- Constants ---
# This path is inside the Airflow container
CONFIG_PATH = Path("/opt/airflow/config/dag_config.csv")

# --- Logging ---
logging.basicConfig(level=logging.INFO)
log = logging.getLogger(__name__)

def create_dag(config: dict):
    """Factory function to create a DAG object from a config dictionary."""
    dag_id = config['layer__data_subject__src']
    log.info(f"Creating DAG: {dag_id}")

    try:
        # --- Parameters from CSV ---
        tags_list = [tag.strip() for tag in config['tags'].split(',')]
        start_date_dt = datetime.strptime(config['start_date'], '%Y-%m-%d')
        catchup_bool = config['catchup'].strip().lower() == 'true'
        schedule = None if config['schedule_interval'].lower() == 'none' else config['schedule_interval']
        description = config.get('description', f'Dynamically generated DAG for {dag_id}')

        # --- DAG Definition ---
        dag = DAG(
            dag_id=dag_id,
            description=description,
            schedule=schedule,
            start_date=start_date_dt,
            catchup=catchup_bool,
            tags=tags_list,
            max_active_runs=int(config['max_active_runs']),
            doc_md=f"### {dag_id}

This DAG is dynamically generated from `dag_config.csv`.",
        )

        with dag:
            TriggerDagRunOperator(
                task_id="trigger_coordinator",
                trigger_dag_id=config['trigger_target'],
                conf={"button": dag_id},
                wait_for_completion=False,
            )
        
        return dag

    except Exception as e:
        log.error(f"Failed to create DAG {dag_id}. Error: {e}", exc_info=True)
        return None

# --- Main DAG Generation Logic ---
log.info("Starting Dynamic DAG generation from CSV...")

if not CONFIG_PATH.is_file():
    log.error(f"DAG Config file not found at {CONFIG_PATH}. No DAGs will be generated.")
else:
    log.info(f"Reading DAG configuration from {CONFIG_PATH}")
    with open(CONFIG_PATH, mode='r', encoding='utf-8') as infile:
        reader = csv.DictReader(infile)
        for row in reader:
            # Check if the DAG is marked as active
            if row.get('dag_active', '0').strip() != '1':
                log.info(f"Skipping inactive DAG: {row.get('layer__data_subject__src')}")
                continue

            # Create the DAG
            new_dag_object = create_dag(row)

            # If DAG creation was successful, add it to globals
            if new_dag_object:
                globals()[new_dag_object.dag_id] = new_dag_object

    log.info("Finished Dynamic DAG generation.")
